# =============================================================================
# Backend environment — copy to .env and fill in values
# Local path: video-streaming/backend/.env
# =============================================================================

# --- AI descriptions (set GEMINI_API_KEY and/or OPENAI_API_KEY) ---
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
# AI_DESCRIPTION_PROVIDER=gemini

# OpenAI (optional fallback if no Gemini key)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=video_delivery
DB_PORT=3306

# --- JWT / session ---
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
JWT_SESSION_EXPIRES_IN=8h
# Set true when frontend and API are on different domains (requires HTTPS)
COOKIE_CROSS_ORIGIN=false

# --- Upload ---
MAX_FILE_SIZE=1073741824
UPLOAD_PATH=../video-storage

# --- URLs ---
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# =============================================================================
# cPanel (production): you can use EITHER backend/.env OR cPanel UI variables.
# Setup Node.js App → Environment Variables:
#   OPENAI_API_KEY = sk-...
#   OPENAI_MODEL   = gpt-4o-mini
#   DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, etc.
# Then click "Restart" on the Node.js app.
# =============================================================================
