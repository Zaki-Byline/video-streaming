# =============================================================================
# Backend environment — copy to .env and fill in values
# Local path: video-streaming/backend/.env
# =============================================================================

# --- OpenAI (required for AI video descriptions) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=video_delivery
DB_PORT=3306

# --- JWT ---
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# --- Upload ---
MAX_FILE_SIZE=1073741824
UPLOAD_PATH=../video-storage

# --- URLs ---
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# =============================================================================
# cPanel (production): you can use EITHER backend/.env OR cPanel UI variables.
# Setup Node.js App → Environment Variables:
#   OPENAI_API_KEY = sk-...
#   OPENAI_MODEL   = gpt-4o-mini
#   DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, etc.
# Then click "Restart" on the Node.js app.
# =============================================================================
